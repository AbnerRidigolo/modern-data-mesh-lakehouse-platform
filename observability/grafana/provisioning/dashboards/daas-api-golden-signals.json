{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "DaaS API — Golden Signals",
  "uid": "daas-api-golden",
  "tags": ["data-mesh", "api", "sre"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Throughput (req/s) por handler",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total{service=\"daas-api\"}[5m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latência p95 (s) por handler",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{service=\"daas-api\"}[5m])))",
          "legendFormat": "p95 {{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latência p50 / p95 / p99 (global)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"daas-api\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"daas-api\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"daas-api\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Taxa de erros 5xx (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{service=\"daas-api\", status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{service=\"daas-api\"}[5m])), 1)",
          "legendFormat": "erro %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Requisições em andamento",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        { "expr": "sum(http_requests_inprogress{service=\"daas-api\"})", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "title": "Total de requisições (janela)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(increase(http_requests_total{service=\"daas-api\"}[1h]))", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "Throughput por status",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total{service=\"daas-api\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    }
  ]
}
